{
  "extends": "@istanbuljs/nyc-config-typescript",
  "excludeAfterRemap": true,
  "check-coverage": true,
  "reporter": ["lcov", "json", "json-summary", "text-summary"],
  "report-dir": "./coverage",
  "include": ["src/**"],
  "exclude": ["node_modules/**", "**/.next/**", "**src/app/", "**src/interfaces"],
  "all": true
}
